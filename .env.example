# ============================================================
# .env.example — 環境変数設定サンプル
# ============================================================
# このファイルをコピーして .env という名前で保存し、
# 実際の値を記入してください。
# .env は絶対に Git にコミットしないでください。
# ============================================================

# Anthropic APIキー（必須）
# 取得先: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-サンプル


# サーバーポート番号（任意。デフォルト: 5000）
# PORT=5000
